NODE_ENV="development"
PORT=3000
# IMPORTANTE: reemplaza TU_PASSWORD por la contraseña real del usuario postgres.
DATABASE_URL="postgresql://postgres:TU_PASSWORD@localhost:5432/sisca_db?schema=public"
CORS_ORIGIN=http://localhost:4200,http://localhost:3000,http://127.0.0.1:4200,http://127.0.0.1:3000
JWT_SECRET="sisca_secret_key_dev"
JWT_EXPIRES_IN="8h"
ENABLE_SWAGGER=false
